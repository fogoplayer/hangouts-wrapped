  "version": "0.2.0",
  "configurations": [
    // Go
    {
      "name": "Launch Program",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/go",
      "args": ["/var/tmp/Temporary Downloads/Council Only/Google Chat"],
      "console": "integratedTerminal"
    },
    {
      "name": "Launch Package",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${fileDirname}"
    },
    // JS
    {
      "command": "npm start",
      "name": "Run npm start",
      "request": "launch",
      "type": "node-terminal"
    },
    {
      "command": "npm test",
      "name": "Run tests",
      "request": "launch",
      "type": "node-terminal"
    },
    {
      "command": "npm lint",
      "name": "Lint project",
      "request": "launch",
      "type": "node-terminal"
    }
  ]
}
