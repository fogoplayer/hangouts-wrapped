{
  "compilerOptions": {
    "lib": ["esnext", "DOM"],
    "moduleResolution": "node",
    "module": "esnext",
    "target": "esnext",
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true
  },
  "include": [
    "src/**/*.js",
    "src/**/*.mjs",
    "src/**/*.d.ts",
    "libs/go-wasm-runtime@1.23.4.d.ts",
    "global.d.ts",
    "App.mjs",
    "mockResults.mjs",
    "service-worker.js"
  ],
  "exclude": ["node_modules"]
}
